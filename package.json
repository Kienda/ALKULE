{
  "name": "alkule",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <23"
  },
  "description": "Alkule — learn the ADLaM script, Fulani language and culture.",
  "scripts": {
    "dev": "node Backend/run.mjs",
    "dev:next": "next dev",
    "build": "next build",
    "start": "node Backend/run.mjs",
    "test:firebase": "node Backend/firebase.test.mjs",
    "test:api": "node Backend/test-runner.mjs",
    "test": "node Backend/firebase.test.mjs && node Backend/test-runner.mjs",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "bootstrap-owner": "node Backend/cli.mjs bootstrap-owner"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "dotenv": "17.4.2",
    "express": "^5.2.1",
    "firebase-admin": "14.2.0",
    "next": "^16.2.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "prisma": "6.19.3",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.3"
  },
  "allowScripts": {
    "prisma@6.19.3": true,
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true,
    "@firebase/util@1.15.1": true,
    "protobufjs@7.6.5": true
  }
