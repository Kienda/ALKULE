rules_version = '2';

// Alkule Firestore security rules.
//
// The Alkule application accesses Firestore exclusively through the trusted
// backend (Firebase Admin SDK), which BYPASSES these rules. Therefore all
// authorization is enforced server-side, and these client-facing rules are
// intentionally restrictive: the browser has no direct Firestore access.
//
// If a future feature intentionally reads Firestore directly from the browser,
// add a narrowly-scoped allow rule for that specific collection and document it
// in docs/AUTHENTICATION.md. Never use `allow read, write: if true;`.

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
