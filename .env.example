# Copy to .env for local development. Never commit the real .env or any secret.

# ─── Firebase (primary: Auth + Firestore + Storage) ─────────────────────────
# Server-only. Set these in Railway. Do NOT prefix with NEXT_PUBLIC_ (that would
# expose them to the browser). For LOCAL dev you may instead drop the
# service-account JSON into Backend/secrets/ (git-ignored) and leave these blank.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the private key with literal \n for newlines, wrapped in quotes. The
# backend normalizes \n to real newlines.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=alkule.firebasestorage.app

# ─── Firebase Web client config (browser, safe to expose) ───────────────────
# These NEXT_PUBLIC_ values are NOT secret; they identify the Firebase project to
# the browser SDK. Get them from Firebase console → Project settings → Your apps.
NEXT_PUBLIC_FIREBASE_API_KEY=your-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=alkule.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# ─── Runtime ────────────────────────────────────────────────────────────────
PORT=3000
API_PORT=4000
NODE_ENV=development

# ─── Legacy / parked: PostgreSQL + Prisma (Phase 1 backend) ─────────────────
# The Postgres backend is parked in favor of Firebase (Firestore). These remain
# only so the Phase 1 snapshot and its tests still run during the migration
# window. Safe to leave unset once the Firestore migration is complete.
DATABASE_URL=postgresql://alkule:CHANGE_ME@localhost:5432/alkule
TEST_DATABASE_URL=postgresql://alkule:CHANGE_ME@localhost:5432/alkule_test
SESSION_SECRET=replace-with-at-least-32-random-characters
# Only used by the legacy owner-bootstrap CLI. Leave unset to auto-generate.
# OWNER_BOOTSTRAP_PASSWORD=
