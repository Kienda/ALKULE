# Copy to .env for local development. Never commit the real .env.

# PostgreSQL connection for the app (use a dedicated least-privilege role, not the superuser).
DATABASE_URL=postgresql://alkule:CHANGE_ME@localhost:5432/alkule
# Separate database used by the integration test suite. Must contain "test" in its name.
TEST_DATABASE_URL=postgresql://alkule:CHANGE_ME@localhost:5432/alkule_test

# Signs session cookies. Use at least 32 random characters. Set a strong value in Railway.
SESSION_SECRET=replace-with-at-least-32-random-characters

# Frontend (Next.js) and backend (Express) ports for local dev. Railway supplies PORT.
PORT=3000
API_PORT=4000

NODE_ENV=development

# Only used by the one-time owner bootstrap CLI to set a known initial password.
# Leave unset to have a random one-time password generated and printed.
# OWNER_BOOTSTRAP_PASSWORD=
